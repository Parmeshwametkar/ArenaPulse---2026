# ArenaPulse 2026 - Environment Variables

# The port the backend server will run on (Default: 3001)
PORT=3001

# Google Gemini API Key. Get yours from Google AI Studio:
# https://aistudio.google.com/
# Leave empty if you plan to provide the key via the frontend UI settings panel.
GEMINI_API_KEY=your_gemini_api_key_here
